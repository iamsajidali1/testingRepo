    <bpmn:callActivity id="Activity_1is8b9q" name="Parse value" calledElement="ParseJsonPath">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="jsonpath">$.data[*].value</camunda:inputParameter>
          <camunda:inputParameter name="firstOnly">1</camunda:inputParameter>
          <camunda:inputParameter name="varname">json</camunda:inputParameter>
        </camunda:inputOutput>
        <camunda:out source="result" target="xlsx" />
        <camunda:in source="jsonpath" target="jsonpath" />
        <camunda:in source="bytes" target="json" />
        <camunda:in source="firstOnly" target="firstOnly" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15amoyc</bpmn:incoming>
      <bpmn:outgoing>Flow_0kwexgo</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_15amoyc" sourceRef="Activity_0gh9l0a" targetRef="Activity_1is8b9q" />
    <bpmn:sequenceFlow id="Flow_0kwexgo" sourceRef="Activity_1is8b9q" targetRef="Activity_0fdrof9" />
    <bpmn:textAnnotation id="TextAnnotation_00n74mn">
