    <bpmn:textAnnotation id="TextAnnotation_0s9tzai">
      <bpmn:text>Expects:
- "emails" (comma-separated)
- "emailBody" (optional)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ckghsz" sourceRef="Activity_0fdrof9" targetRef="TextAnnotation_0s9tzai" />
