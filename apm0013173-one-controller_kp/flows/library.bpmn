          <camunda:inputParameter name="vcoPassword">${vcoPassword}</camunda:inputParameter>
          <camunda:outputParameter name="xlsx">${xlsx}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_15jexvh" name="Send E-mail via Paperplane" camunda:type="external" camunda:topic="X-PaperplaneSendEmailXlsx">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="xlsx">${xlsx}</camunda:inputParameter>
          <camunda:inputParameter name="emails">${emails}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_171n7tq" name="HTTP call" camunda:type="external" camunda:topic="X-HttpRequest">
