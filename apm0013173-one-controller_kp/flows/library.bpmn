          <camunda:outputParameter name="headers">${headers}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:task id="Activity_07addmu" name="Get env variable">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="input">
            <camunda:script scriptFormat="JavaScript">(java.lang.System).getenv('ENV_VARIABLE')</camunda:script>
          </camunda:inputParameter>
          <camunda:outputParameter name="output">${input}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:task>
  </bpmn:process>
