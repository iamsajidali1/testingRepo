  <bpmn:process id="Process_1dywr8u" isExecutable="true">
    <bpmn:serviceTask id="Activity_0b1oied" name="Print" camunda:type="external" camunda:topic="X-Print">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="input">${input}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1qovccr" name="Generate MDS from VCO" camunda:type="external" camunda:topic="X-GenerateMdsVelocloud">
