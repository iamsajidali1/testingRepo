          <camunda:inputParameter name="ignoreCertificate">${ignoreCertificate}</camunda:inputParameter>
          <camunda:inputParameter name="headers">${headers}</camunda:inputParameter>
          <camunda:inputParameter name="useProxy">${useProxy}</camunda:inputParameter>
          <camunda:inputParameter name="proxyProtocol">${proxyProtocol}</camunda:inputParameter>
          <camunda:inputParameter name="proxyHost">${proxyHost}</camunda:inputParameter>
          <camunda:inputParameter name="proxyPort">${proxyPort}</camunda:inputParameter>
          <camunda:outputParameter name="status">${status}</camunda:outputParameter>
          <camunda:outputParameter name="statusText">${statusText}</camunda:outputParameter>
          <camunda:outputParameter name="bytes">${bytes}</camunda:outputParameter>
          <camunda:outputParameter name="headers">${headers}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1iaz8t0" name="AAF Authorized HTTP call" camunda:type="external" camunda:topic="X-HttpRequest-Aaf">
