  <bpmn:process id="MdsVelocloud" name="MdsVelocloud" isExecutable="true" camunda:versionTag="0.3">
    <bpmn:startEvent id="StartEvent_1" name="Start process">
      <bpmn:outgoing>Flow_0favobl</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task-GenerateMdsVelocloud" name="Generate MDS from VCO" camunda:type="external" camunda:topic="X-GenerateMdsVelocloud">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="vcoProtocol">${vcoProtocol}</camunda:inputParameter>
          <camunda:inputParameter name="vcoHostname">${vcoHostname}</camunda:inputParameter>
          <camunda:inputParameter name="vcoUsername">${vcoUsername}</camunda:inputParameter>
          <camunda:inputParameter name="vcoPassword">${vcoPassword}</camunda:inputParameter>
          <camunda:outputParameter name="xlsx">${xlsx}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0favobl</bpmn:incoming>
      <bpmn:outgoing>Flow_0fo5cdg</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0fo5cdg" sourceRef="Task-GenerateMdsVelocloud" targetRef="Task-PaperplaneSendEmail" />
    <bpmn:endEvent id="Event_0muqo7i" name="End process">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="output" />
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1a7yy0j</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0favobl" sourceRef="StartEvent_1" targetRef="Task-GenerateMdsVelocloud" />
    <bpmn:sequenceFlow id="Flow_1a7yy0j" sourceRef="Task-PaperplaneSendEmail" targetRef="Event_0muqo7i" />
    <bpmn:serviceTask id="Task-PaperplaneSendEmail" name="Send E-mail via Paperplane" camunda:type="external" camunda:topic="X-PaperplaneSendEmailXlsx">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="xlsx">${xlsx}</camunda:inputParameter>
          <camunda:inputParameter name="emails">${emails}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0fo5cdg</bpmn:incoming>
      <bpmn:outgoing>Flow_1a7yy0j</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
