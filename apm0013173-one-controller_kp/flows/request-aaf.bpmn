    <bpmn:callActivity id="Activity_0jcnofz" name="Print&#10;(single node)" calledElement="Print">
      <bpmn:extensionElements>
        <camunda:in source="result" target="input" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0290x9z</bpmn:incoming>
      <bpmn:outgoing>Flow_1og4jon</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_1og4jon" sourceRef="Activity_0jcnofz" targetRef="Event_0muqo7i" />
    <bpmn:scriptTask id="Activity_0zeg4wv" name="Pick single node" scriptFormat="javascript" camunda:resultVariable="result">
      <bpmn:documentation>Zip hosts and ports into an array of objects and randomly provide single object from the array as a response.</bpmn:documentation>
      <bpmn:incoming>Flow_11e6cpv</bpmn:incoming>
      <bpmn:outgoing>Flow_0290x9z</bpmn:outgoing>
      <bpmn:script>// Parse incoming JSON object (Jackson Java node)
var hosts = JSON.parse(resultHost);
var ports = JSON.parse(resultPort);
var left = hosts.length;
var right = ports.length;
var length = Math.min(left, right);

var result = [];

// Zip and concatenate array values
let idx;
for (idx = 0; idx &lt; left; idx++) {
    result.push(hosts[idx] + ":" + ports[idx].toString());
}

// Create pseudo-random index
idx = Math.floor(Math.random() * (length - 1));
result = result[idx];

// Return single string "host:port"
result;</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0290x9z" sourceRef="Activity_0zeg4wv" targetRef="Activity_0jcnofz" />
  </bpmn:process>
