    <bpmn:exclusiveGateway id="Gateway_0rktk5l" name="Iteration decision" default="Flow_1jtye1j">
      <bpmn:incoming>Flow_1grjfi0</bpmn:incoming>
      <bpmn:outgoing>Flow_1akdvfe</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jtye1j</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1akdvfe" name="end" sourceRef="Gateway_0rktk5l" targetRef="Event_1uztklq">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="groovy">import groovy.json.JsonSlurper
iteration = execution.getVariable("crypt_iteration")
iteration = iteration + 1
println iteration
crypt_array = execution.getVariable("cryptBody")
def jsonSlurper = new JsonSlurper()
def crypt_array_json = jsonSlurper.parseText(crypt_array)
crypt_array_size = crypt_array_json.size()
println crypt_array_size
crypt_array_size == iteration

</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:task id="Activity_04dqy73" name="iterate">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="crypt_iteration">
            <camunda:script scriptFormat="groovy">iteration = execution.getVariable("crypt_iteration")
crypt_iteration = iteration + 1</camunda:script>
          </camunda:outputParameter>
          <camunda:outputParameter name="xlsx">[]</camunda:outputParameter>
        </camunda:inputOutput>
