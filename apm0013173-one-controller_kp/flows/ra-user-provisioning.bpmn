    <bpmn:serviceTask id="Activity_0fdrof9" name="Send E-mail via Paperplane" camunda:type="external" camunda:topic="X-PaperplaneSendEmailXlsx">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="emails">${emails}</camunda:inputParameter>
          <camunda:inputParameter name="body">${execution.getVariable("ra_result")}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1pvyjnx</bpmn:incoming>
      <bpmn:outgoing>Flow_1grjfi0</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1grjfi0" sourceRef="Activity_0fdrof9" targetRef="Gateway_0rktk5l" />
    <bpmn:task id="Activity_0vrz9hj" name="Initialize Variables">
      <bpmn:documentation>creates loop around cryptdata</bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="crypt_iteration">
            <camunda:script scriptFormat="groovy">int crypt_iteration = 0</camunda:script>
          </camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0cujpjh</bpmn:incoming>
      <bpmn:outgoing>Flow_1cw8o3d</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1cw8o3d" sourceRef="Activity_0vrz9hj" targetRef="Activity_0ovl3n0" />
    <bpmn:sequenceFlow id="Flow_0cujpjh" sourceRef="Event_13jf6db" targetRef="Activity_0vrz9hj" />
    <bpmn:exclusiveGateway id="Gateway_0rktk5l" name="Iteration decision" default="Flow_1jtye1j">
      <bpmn:incoming>Flow_1grjfi0</bpmn:incoming>
      <bpmn:outgoing>Flow_1akdvfe</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jtye1j</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1akdvfe" name="end" sourceRef="Gateway_0rktk5l" targetRef="Event_1uztklq">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" language="groovy">import groovy.json.JsonSlurper
iteration = execution.getVariable("crypt_iteration")
iteration = iteration + 1
println iteration
crypt_array = execution.getVariable("cryptBody")
def jsonSlurper = new JsonSlurper()
def crypt_array_json = jsonSlurper.parseText(crypt_array)
crypt_array_size = crypt_array_json.size()
println crypt_array_size
crypt_array_size == iteration

</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:task id="Activity_04dqy73" name="iterate">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="crypt_iteration">
            <camunda:script scriptFormat="groovy">iteration = execution.getVariable("crypt_iteration")
crypt_iteration = iteration + 1</camunda:script>
          </camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jtye1j</bpmn:incoming>
      <bpmn:outgoing>Flow_14pb8ku</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1jtye1j" name="else" sourceRef="Gateway_0rktk5l" targetRef="Activity_04dqy73" />
    <bpmn:sequenceFlow id="Flow_14pb8ku" sourceRef="Activity_04dqy73" targetRef="Activity_0ovl3n0" />
