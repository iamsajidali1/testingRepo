<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_0npr23n" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.22.0">
  <bpmn:process id="RAUserProvisioning" name="UserProvisioning" isExecutable="true" camunda:versionTag="1" camunda:historyTimeToLive="90">
    <bpmn:callActivity id="Activity_04t3am9" name="Decode bytes" calledElement="Base64Decode">
      <bpmn:extensionElements>
        <camunda:in source="bytes" target="input" />
        <camunda:out variables="all" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_12fehc8</bpmn:incoming>
      <bpmn:outgoing>Flow_06efneu</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="Activity_0gh9l0a" name="POST report to RA" calledElement="HttpRequest">
      <bpmn:extensionElements>
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:inputOutput>
          <camunda:inputParameter name="method">post</camunda:inputParameter>
          <camunda:inputParameter name="url">
            <camunda:script scriptFormat="JavaScript">var baseurl = java.lang.System.getenv("RA_VELOCLOUD_URL") 
// https://ra-velo-on-k8s/api + "/report" + /report/billing
baseurl + "/user/add";</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="body">
            <camunda:script scriptFormat="javascript">var device = execution.getVariable("devices");
var param = execution.getVariable("params");
//body = [];
//body.add(device);
//body.add(param);


var json = S('{}');
var json_d = S(device);
var json_p = S(param)
json.prop("devices",json_d);
json.prop("params",json_p);
body = json;</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="ignoreCertificate">${false}</camunda:inputParameter>
          <camunda:inputParameter name="headers">
            <camunda:script scriptFormat="JavaScript">var output = execution.getVariable("output");
output = JSON.parse(output);
output = output[0];
var crypt_body = execution.getVariable("cryptBody");
var iteration = execution.getVariable("iteration_body");
var json = S(crypt_body);
var bodies = json.elements();
body = bodies.get(iteration);
var url = output["url"];
var user = output["username"];
var pass = output["password"];
//var tenant = execution.getVariable("tenantid")
var tenant = body.prop("tenantid").value();
var headers = ["Content-Type: application/json"];
// Wait for Ondrej to fix proto prefix in RA
//url = url.replace("https://", "").replace("http://", "");

headers.push("X-Url: " + url);
headers.push("X-Username: " + user);
headers.push("X-Password: " + pass);
headers.push("X-Tenant-Id: " + tenant);
headers.join("\n");</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="useProxy">${false}</camunda:inputParameter>
          <camunda:inputParameter name="proxyProtocol">http</camunda:inputParameter>
          <camunda:inputParameter name="proxyHost">pxyapp.proxy.att.com</camunda:inputParameter>
          <camunda:inputParameter name="proxyPort">${8080}</camunda:inputParameter>
          <camunda:outputParameter name="status">${status}</camunda:outputParameter>
          <camunda:outputParameter name="statusText">${statusText}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_06efneu</bpmn:incoming>
      <bpmn:outgoing>Flow_0mxey3o</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="Event_1uztklq" name="End process">
      <bpmn:incoming>Flow_1akdvfe</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="Activity_0ovl3n0" name="Crypt" calledElement="HttpRequest">
      <bpmn:extensionElements>
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:inputOutput>
          <camunda:inputParameter name="method">post</camunda:inputParameter>
          <camunda:inputParameter name="url">
            <camunda:script scriptFormat="JavaScript">// http://crypt-on-k8s/api/v1/credentials/
java.lang.System.getenv("CRYPT_URL") + "/api/v1/credentials/";</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="body">
            <camunda:script scriptFormat="javascript">var crypt_body = execution.getVariable("cryptBody");
var iteration = execution.getVariable("crypt_iteration");
var json = S(crypt_body);
var bodies = json.elements();
body = bodies.get(iteration);
</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="ignoreCertificate">${false}</camunda:inputParameter>
          <camunda:inputParameter name="headers">
            <camunda:script scriptFormat="JavaScript">var token = java.lang.System.getenv("CRYPT_API_TOKEN")
token = "Authorization: Token " + token;
headers = token + "\r\nContent-Type: application/json";</camunda:script>
          </camunda:inputParameter>
          <camunda:inputParameter name="useProxy">${false}</camunda:inputParameter>
          <camunda:inputParameter name="proxyProtocol">http</camunda:inputParameter>
          <camunda:inputParameter name="proxyHost">pxyapp.proxy.att.com</camunda:inputParameter>
          <camunda:inputParameter name="proxyPort">${8080}</camunda:inputParameter>
          <camunda:outputParameter name="status">${status}</camunda:outputParameter>
          <camunda:outputParameter name="statusText">${statusText}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1cw8o3d</bpmn:incoming>
      <bpmn:incoming>Flow_14pb8ku</bpmn:incoming>
      <bpmn:outgoing>Flow_12fehc8</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_12fehc8" sourceRef="Activity_0ovl3n0" targetRef="Activity_04t3am9" />
