    "@angular/platform-browser": "^14.0.0",
    "@angular/platform-browser-dynamic": "^14.0.0",
    "@angular/router": "^14.0.0",
    "@swimlane/ngx-charts": "^20.1.0",
    "bootstrap": "^5.1.3",
    "chart.js": "^4.4.2",
